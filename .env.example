# claude-tools-dashboard configuration
# All values shown are defaults -- only set what you need to override.

# Dashboard listen port
PORT=8095

# Headroom proxy URL (stats and health endpoints)
HEADROOM_URL=http://127.0.0.1:8787

# RTK SQLite database path
RTK_DB_PATH=~/.local/share/rtk/history.db

# RTK binary name or path (uses PATH by default)
RTK_BIN=rtk

# jCodeMunch index directory (contains _savings.json and .db files)
JCODEMUNCH_INDEX_DIR=~/.code-index

# jCodeMunch binary name or path (used for version check)
JCODEMUNCH_BIN=jcodemunch-mcp

# SSE poll/push interval in seconds
SSE_INTERVAL=30
