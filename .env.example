# claude-room configuration
# All values shown are defaults — only set what you need to override.

# Dashboard listen port
PORT=8095

# Headroom proxy base URL (/stats and /health)
HEADROOM_URL=http://127.0.0.1:8787

# RTK SQLite database path
RTK_DB_PATH=~/.local/share/rtk/history.db

# RTK binary name or path (uses PATH by default)
RTK_BIN=rtk

# Override RTK version string (skip binary probe — useful in containers)
# RTK_VERSION=0.5.2

# Background collector tick interval in seconds
COLLECTOR_INTERVAL=0.25

# SSE push interval in seconds
SSE_INTERVAL=2

# Directory for weekly savings snapshots
WEEKLY_CACHE_DIR=~/.cache/claude-tools-dashboard
